# Database
DATABASE_URL=postgresql://user:password@localhost:5432/luca

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Mailgun
MAILGUN_API_KEY=key-xxx
MAILGUN_DOMAIN=tanzillo.ai
MAILGUN_WEBHOOK_SIGNING_KEY=xxx

# Claude API
ANTHROPIC_API_KEY=sk-ant-xxx

# Google Calendar OAuth
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URI=https://luca.tanzillo.ai/auth/google/callback

# Google Maps (Places Autocomplete for locations)
GOOGLE_MAPS_API_KEY=xxx

# iMessage Gateway
IMESSAGE_GATEWAY_URL=http://mac-mini.tailnet:3001

# Supabase (shared auth with Tessio)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-dashboard

# App
PORT=3000
APP_URL=https://tanzillo.ai
NODE_ENV=development
